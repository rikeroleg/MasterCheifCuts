# ── application-local-secrets.properties ───────────────────────────────────────
# Local development secrets — DO NOT COMMIT (gitignored)
#
# Copy this file to application-local-secrets.properties and fill in the values.
# ───────────────────────────────────────────────────────────────────────────────

# JWT (min 32 characters)
JWT_SECRET=

# SQL Server
DB_HOST=localhost
DB_USER=
DB_PASS=
DB_NAME=

# Stripe sandbox
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (leave blank to disable in local dev)
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
