{
  "family": "masterchefcuts",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "masterchefcuts",
      "image": "ACCOUNT_ID.dkr.ecr.AWS_REGION.amazonaws.com/masterchefcuts:latest",
      "portMappings": [
        {
          "containerPort": 8081,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "aws" },
        { "name": "SERVER_PORT",            "value": "8081" }
      ],
      "secrets": [
        { "name": "DB_HOST",         "valueFrom": "arn:aws:secretsmanager:AWS_REGION:ACCOUNT_ID:secret:masterchefcuts/prod:DB_HOST::" },
        { "name": "DB_PORT",         "valueFrom": "arn:aws:secretsmanager:AWS_REGION:ACCOUNT_ID:secret:masterchefcuts/prod:DB_PORT::" },
        { "name": "DB_NAME",         "valueFrom": "arn:aws:secretsmanager:AWS_REGION:ACCOUNT_ID:secret:masterchefcuts/prod:DB_NAME::" },
        { "name": "DB_USER",         "valueFrom": "arn:aws:secretsmanager:AWS_REGION:ACCOUNT_ID:secret:masterchefcuts/prod:DB_USER::" },
        { "name": "DB_PASS",         "valueFrom": "arn:aws:secretsmanager:AWS_REGION:ACCOUNT_ID:secret:masterchefcuts/prod:DB_PASS::" },
        { "name": "JWT_SECRET",      "valueFrom": "arn:aws:secretsmanager:AWS_REGION:ACCOUNT_ID:secret:masterchefcuts/prod:JWT_SECRET::" },
        { "name": "STRIPE_SECRET_KEY","valueFrom": "arn:aws:secretsmanager:AWS_REGION:ACCOUNT_ID:secret:masterchefcuts/prod:STRIPE_SECRET_KEY::" },
        { "name": "MAIL_HOST",       "valueFrom": "arn:aws:secretsmanager:AWS_REGION:ACCOUNT_ID:secret:masterchefcuts/prod:MAIL_HOST::" },
        { "name": "MAIL_PORT",       "valueFrom": "arn:aws:secretsmanager:AWS_REGION:ACCOUNT_ID:secret:masterchefcuts/prod:MAIL_PORT::" },
        { "name": "MAIL_USER",       "valueFrom": "arn:aws:secretsmanager:AWS_REGION:ACCOUNT_ID:secret:masterchefcuts/prod:MAIL_USER::" },
        { "name": "MAIL_PASS",       "valueFrom": "arn:aws:secretsmanager:AWS_REGION:ACCOUNT_ID:secret:masterchefcuts/prod:MAIL_PASS::" },
        { "name": "MAIL_FROM",       "valueFrom": "arn:aws:secretsmanager:AWS_REGION:ACCOUNT_ID:secret:masterchefcuts/prod:MAIL_FROM::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/masterchefcuts",
          "awslogs-region":        "AWS_REGION",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command":     ["CMD-SHELL", "curl -f http://localhost:8081/participant/actuator/health || exit 1"],
        "interval":    30,
        "timeout":     10,
        "retries":     3,
        "startPeriod": 60
      }
    }
  ]
}
